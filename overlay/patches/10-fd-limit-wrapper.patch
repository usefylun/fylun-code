+  // Fylun Code: macOS/Linux ship `fylun-code` as a thin shell wrapper that
+  // raises this process's own fd soft limit to the OS-permitted max before
+  // exec'ing the real binary (renamed `fylun-code-bin`). macOS defaults new
+  // shells to a 256 fd limit, which file watching/sync on startup can
+  // exceed; this only adjusts the limit for this process, not the user's
+  // shell or system. Applies to every build (local + release), not just
+  // release archives. Windows has no equivalent rlimit concept, so leave
+  // fylun-code.exe untouched there.
+  if (item.os !== "win32") {
+    await $`mv dist/${name}/bin/fylun-code dist/${name}/bin/fylun-code-bin`
+    await Bun.file(`dist/${name}/bin/fylun-code`).write(
+      [
+        "#!/bin/sh",
+        "ulimit -n 65536 2>/dev/null || true",
+        'dir="$(cd "$(dirname "$0")" && pwd)"',
+        'exec "$dir/fylun-code-bin" "$@"',
+        "",
+      ].join("\n"),
+    )
+    await $`chmod +x dist/${name}/bin/fylun-code`
+  }
+
+  // Fylun Code: ship the MIT license (opencode + Fylun overlay) inside every
+  // release archive so the copyright/permission notice travels with copies.
+  await $`cp ../../../LICENSE dist/${name}/bin/LICENSE`
+
