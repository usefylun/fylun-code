// Fylun Code default global config. Installer places this at
// ~/.config/fylun-code/fyluncode.jsonc. Models block is GENERATED from
// @fylun/ai ModelRegistry (same source as /api/v1/models + the baked catalog).
// COST NOTE: rates are provider list price x1.2 (Fylun's flat markup) with
// cache tiers (cache_read = 0.1x input for openai/anthropic/google/deepseek,
// 0.25x for xai; cache_write = 1.25x input, Anthropic only) so the TUI's
// session estimate matches what the wallet is actually debited. Keep in sync
// with models-fylun.json and fylun-web translate.ts multipliers.
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  // Palenight — matches Fylun's violet brand in the terminal.
  "theme": "palenight",
  // Never surface anomalyco's Zen gateway provider.
  "disabled_providers": ["opencode"],
  // No "plugin" entry: Fylun auth is compiled into the binary (internalPlugins).
  "model": "fylun/deepseek-v4-flash",
  // Cheap model for side-tasks (titles, compaction summaries). Without this
  // opencode falls back to the MAIN model — running title generation on a
  // frontier model like gpt-5.6-sol at frontier prices.
  "small_model": "fylun/gemini-3.1-flash-lite",
  "provider": {
    "fylun": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fylun",
      "options": { "baseURL": "https://fylun.ai/api/v1" },
      "models": {
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Sol",
          "reasoning": true,
          "limit": {
            "context": 1000000,
            "output": 65536
