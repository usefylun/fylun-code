// Fylun Code default global config. Installer places this at
// ~/.config/fylun-code/fyluncode.jsonc (seeded once, never overwritten on
// upgrade). It carries ONLY user-facing defaults + the Fylun provider
// endpoint. The model catalog is NOT listed here: models, pricing, and
// context limits come from the models.dev snapshot baked into the binary
// (distribution/models-fylun.json, generated from @fylun/ai ModelRegistry),
// so a plain `fylun-code upgrade` always ships the current catalog with no
// stale on-disk config to refresh.
{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  // Palenight — matches Fylun's violet brand in the terminal.
  "theme": "palenight",
  // Never surface anomalyco's Zen gateway provider.
  "disabled_providers": ["opencode"],
  // No "plugin" entry: Fylun auth is compiled into the binary (internalPlugins).
  "model": "fylun/deepseek-v4-flash",
  // Cheap model for side-tasks (titles, compaction summaries). Without this
  // opencode falls back to the MAIN model — running title generation on a
  // frontier model like gpt-5.6-sol at frontier prices.
  "small_model": "fylun/gemini-3.1-flash-lite",
  "provider": {
    "fylun": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Fylun",
      "options": { "baseURL": "https://fylun.ai/api/v1" }
    }
  }
}
